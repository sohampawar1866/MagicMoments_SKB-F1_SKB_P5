# Environment
venv/
env/
.venv/
.env

# Python
__pycache__/
*.pyc
*.pyo
*.pye
*.pyd
*.zip
*.egg
*.egg-info/
dist/
build/
.pytest_cache/

# OS specific
.DS_Store
Thumbs.db

# Project Data / Over-sized files
# NOTE: using data/* (not data/) so we can re-include specific subdirs below.
data/*
*.geojson
*.shp
*.gpkg

# Phase 3 D-11: commit the trimmed Indian EEZ coastline basemap (< 100 KB)
!data/basemap/
!data/basemap/*

# Phase 3 D-13 + D-16: commit pre-baked 4-AOI fallback JSONs (< 50 KB total)
# Required on disk at demo time for silent fallback per D-12. Regenerate with
# `python -m scripts.prebake_demo` whenever weights or MARIDA change.
!data/prebaked/
!data/prebaked/*

# MARIDA dataset (4.5 GB — PITFALL mi3, never commit)
MARIDA/

# Model checkpoints (PITFALL M12 — use kagglehub, not git)
# NOTE: kagglehub caches to ~/.cache/kagglehub/ which is OUTSIDE the repo,
# so no gitignore rule is needed for it. The *.pth and *.ckpt rules below
# catch any in-repo checkpoints if someone accidentally copies one in.
*.pth
*.ckpt

# ML checkpoints (user-supplied, gitignored per D-02 + INFRA-05)
backend/ml/checkpoints/*.pt
backend/ml/checkpoints/*.pth
backend/ml/checkpoints/*.pkl
backend/ml/checkpoints/*.ckpt
!backend/ml/checkpoints/.gitkeep
data/env/*.nc

# Phase metrics (generated at runtime)
.planning/metrics/

# Node (for future frontend)
node_modules/.tmp_e2e/

