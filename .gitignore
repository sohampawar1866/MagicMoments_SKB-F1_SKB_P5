# =====================
# Data / large artifacts
# =====================
# Keep only whitelisted demo artifacts under /data.
data/*
!data/basemap/
!data/basemap/**
!data/prebaked/
!data/prebaked/**

# Backend runtime/cache data (keep coastline source file only).
backend/data/*
!backend/data/india_coastline_segmented.geojson

# NetCDF + rasters (downloaded/generated)
data/env/*.nc
backend/data/*.nc
*.tif
*.tiff

# Vector sidecar files generated from shapefiles
*.gpkg
*.shp
*.shx
*.dbf
*.cpg
*.prj

# MARIDA dataset (very large)
MARIDA/

# Model checkpoints (never commit trained weights)
*.pth
*.ckpt
backend/ml/checkpoints/*.pt
backend/ml/checkpoints/*.pth
backend/ml/checkpoints/*.pkl
backend/ml/checkpoints/*.ckpt
!backend/ml/checkpoints/.gitkeep

# Generated metrics
.planning/metrics/
