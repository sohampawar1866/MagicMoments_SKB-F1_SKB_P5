# DRIFT frontend — environment template
# Copy to `.env` for local dev: `cp .env.example .env`

# API path prefix used by the frontend client.
# Keep this as /api/v1 unless your backend exposes a different prefix.
VITE_API_PREFIX=/api/v1

# Base URL for API calls. Default matches `uvicorn backend.main:app --port 8000`.
# Empty -> same-origin + /api/v1/* (use Vite proxy in dev).
VITE_API_BASE_URL=http://localhost:8000

# Dev server proxy target used by Vite for /api, /docs, and /openapi.json.
VITE_DEV_API_TARGET=http://localhost:8000
